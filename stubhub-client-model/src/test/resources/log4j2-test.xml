<?xml version="1.0" encoding="UTF-8"?>
<Configuration>
	<Appenders>
		<Console name="console" target="SYSTEM_OUT">
			<ThresholdFilter level="INFO" onMatch="ACCEPT" onMismatch="DENY" />
			<PatternLayout pattern="%style{%d{HH:mm:ss}}{cyan} %highlight{%-5p} %style{[%t]}{blue} %style{%C{1}}{magenta} %style{(%F:%L)}{yellow} - %m%n" />
		</Console>
		<RollingRandomAccessFile name="file"
			fileName="target/log/stubhub-client-model.log"
			filePattern="target/log/stubhub-client-model-%d{yyyy-MM-dd}-%i.log.gz">
			<PatternLayout charset="UTF-8">
				<Pattern>%d %-6p [%t] %C{1.}.%M:%L %m%n</Pattern>
			</PatternLayout>
			<Policies>
				<OnStartupTriggeringPolicy />
			</Policies>
			<DefaultRolloverStrategy max="7" />
		</RollingRandomAccessFile>
	</Appenders>
	<Loggers>
		<Logger name="org.apache.cxf" level="INFO" additivity="false">
			<AppenderRef ref="console" />
			<AppenderRef ref="file" />
		</Logger>
		<Logger name="org.oxerr.stubhub.client.model" level="ALL" additivity="false">
			<AppenderRef ref="console" />
			<AppenderRef ref="file" />
		</Logger>
		<Root level="WARN">
			<AppenderRef ref="console" />
			<AppenderRef ref="file" />
		</Root>
	</Loggers>
</Configuration>
