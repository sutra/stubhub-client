<?xml version="1.0" encoding="UTF-8"?>
<Configuration>
	<Properties>
		<Property name="app.log.dir">${sys:log.dir:-target/log}</Property>
		<Property name="app.name">${sys:application.name:-stubhub-client-cxf-impl}</Property>
		<Property name="pattern.console">%d %-5p [%t] %C{2} (%F:%L) - %m%n</Property>
		<Property name="pattern.file"   >%d %-5p [%t] %C{1.}.%M:%L %m%n</Property>
	</Properties>
	<Appenders>
		<Console name="console" target="SYSTEM_OUT">
			<ThresholdFilter level="INFO" onMatch="ACCEPT" onMismatch="DENY" />
			<PatternLayout pattern="${pattern.console}" />
		</Console>
		<RollingRandomAccessFile name="file"
			fileName="${app.log.dir}/${app.name}.log"
			filePattern="${app.log.dir}/${app.name}-%d{yyyy-MM-dd}-%i.log.gz">
			<PatternLayout charset="UTF-8" pattern="${pattern.file}" />
			<Policies>
				<OnStartupTriggeringPolicy />
			</Policies>
			<DefaultRolloverStrategy fileIndex="nomax">
				<Delete basePath="${app.log.dir}" maxDepth="1">
					<IfFileName glob="*/${app.name}-????-??-??-*.log.gz" />
					<IfLastModified age="30d" />
				</Delete>
			</DefaultRolloverStrategy>
		</RollingRandomAccessFile>
		<RollingRandomAccessFile name="cxf"
			fileName="${app.log.dir}/${app.name}-cxf.log"
			filePattern="${app.log.dir}/${app.name}-cxf-%d{yyyy-MM-dd}-%i.log.gz">
			<PatternLayout charset="UTF-8" pattern="${pattern.file}" />
			<Policies>
				<OnStartupTriggeringPolicy />
			</Policies>
			<DefaultRolloverStrategy fileIndex="nomax">
				<Delete basePath="${app.log.dir}" maxDepth="1">
					<IfFileName glob="*/${app.name}-cxf-????-??-??-*.log.gz" />
					<IfLastModified age="30d" />
				</Delete>
			</DefaultRolloverStrategy>
		</RollingRandomAccessFile>
	</Appenders>
	<Loggers>
		<Logger name="org.apache.cxf" level="INFO" additivity="false">
			<AppenderRef ref="cxf" />
		</Logger>
		<Logger name="org.oxerr.stubhub.client.cxf.impl" level="ALL" additivity="false">
			<AppenderRef ref="console" />
			<AppenderRef ref="file" />
		</Logger>
		<Root level="WARN">
			<AppenderRef ref="console" />
			<AppenderRef ref="file" />
		</Root>
	</Loggers>
</Configuration>
